    "audit:repo": "node tools/repo-audit.js",
    "check:avatars": "node tools/check-avatar-catalog.js",
    "check:frames": "node tools/check-frame-picker.js",
    "check:progression": "node tools/check-progression.js",
    "check:bootstrap": "node tools/check-bootstrap-rewards.js",
    "check:errors": "node tools/check-error-visibility.js",
    "check:maintenance": "node tools/check-maintenance-route.js",
    "check:legacy-phase9": "node tools/check-legacy-clean-phase9.js",
    "check:home-phase10": "node tools/check-home-phase10.js",
    "check:chat-phase11": "node tools/check-chat-retention-phase11.js",
    "check:security-phase0": "node tools/check-security-phase0.js",
    "check:economy-phase1": "node tools/check-economy-phase1.js",
